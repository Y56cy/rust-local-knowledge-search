{
  "docs_dir": "./docs",
  "index_dir": "./knowledge_index",
  "data_dir": "./knowledge_data",
  "max_file_bytes": 2097152,
  "supported_extensions": [
    "txt",
    "md",
    "rs",
    "toml",
    "json",
    "csv",
    "log",
    "yaml",
    "yml",
    "docx",
    "pdf"
  ],
  "default_limit": 10,
  "snippet_chars": 160
}